<Window x:Class="Zasobowo.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zasobowo" Height="600" Width="1000">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <!-- FORMULARZ -->
        <StackPanel Grid.Column="0" Margin="10" VerticalAlignment="Top">
            <TextBlock Text="ID:" />
            <TextBox x:Name="IdBox" IsReadOnly="True" Margin="0,0,0,10"/>

            <TextBlock Text="Nazwa:" />
            <TextBox x:Name="NameBox" Margin="0,0,0,10"/>

            <TextBlock Text="Status:" />
            <TextBox x:Name="StatusBox" Margin="0,0,0,10"/>

            <TextBlock Text="Przypisany do:" />
            <TextBox x:Name="AssignedToBox" Margin="0,0,0,10"/>

            <TextBlock Text="Typ:" />
            <TextBox x:Name="TypeBox" Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button Content="Dodaj" Click="AddDevice_Click" Width="80" Margin="5"/>
                <Button Content="Aktualizuj" Click="UpdateDevice_Click" Width="80" Margin="5"/>
                <Button Content="Usuń" Click="DeleteDevice_Click" Width="80" Margin="5"/>
                <Button Content="Wyczyść" Click="ClearForm_Click" Width="80" Margin="5"/>
            </StackPanel>
        </StackPanel>

        <!-- TABELA -->
        <DataGrid x:Name="DeviceGrid"
                  Grid.Column="1"
                  AutoGenerateColumns="True"
                  Margin="10"
                  SelectionChanged="DeviceGrid_SelectionChanged" />
    </Grid>
</Window>
