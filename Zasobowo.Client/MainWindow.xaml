<Window x:Class="Zasobowo.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zasobowo – BitPol Tech Solutions"
        Height="640" Width="1320"
        MinHeight="640" MinWidth="1320"
        Background="#FAFAFA">

    <DockPanel>
        <!-- Nagłówek -->
        <Border Background="#1E88E5" DockPanel.Dock="Top" Padding="10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           Text="&#xE7F8;"
                           FontSize="28"
                           Foreground="White"
                           Margin="0,0,10,0"/>
                <TextBlock Text="BitPol Tech Solutions – Zasobowo"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Treść -->
        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3.2*" />
                <!-- ⬅️ szersza lewa kolumna -->
                <ColumnDefinition Width="2.8*" />
                <!-- ⬅️ węższy formularz -->
            </Grid.ColumnDefinitions>

            <!-- Lista urządzeń -->
            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="10" Margin="0,0,20,0" BorderBrush="#DDDDDD" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Lista urządzeń:" FontWeight="Bold" Margin="0,0,0,10"/>
                    <DataGrid x:Name="DeviceGrid"
                              AutoGenerateColumns="False"
                              SelectionMode="Single"
                              SelectionChanged="DeviceGrid_SelectionChanged"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              CanUserResizeColumns="False"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="180"/>
                            <DataGridTextColumn Header="Typ" Binding="{Binding Type}" Width="150"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="150"/>
                            <DataGridTextColumn Header="Przypisany użytkownik" Binding="{Binding AssignedUser.Username}" Width="300"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Formularz -->
            <Border Grid.Column="1" Background="#FFFFFF" CornerRadius="10" Padding="20" BorderBrush="#DDDDDD" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Nazwa urządzenia:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="NameTextBox" Margin="0,0,0,15" Padding="5"/>

                    <TextBlock Text="Typ:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="TypeComboBox" Margin="0,0,0,15" Padding="5">
                        <ComboBoxItem Content="Laptop"/>
                        <ComboBoxItem Content="Monitor"/>
                        <ComboBoxItem Content="Telefon"/>
                        <ComboBoxItem Content="Tablet"/>
                        <ComboBoxItem Content="Router"/>
                    </ComboBox>

                    <TextBlock Text="Status:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="StatusComboBox" Margin="0,0,0,15" Padding="5">
                        <ComboBoxItem Content="Dostępny"/>
                        <ComboBoxItem Content="Przydzielony"/>
                        <ComboBoxItem Content="Zepsuty"/>
                    </ComboBox>

                    <TextBlock Text="Przypisany użytkownik:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="UserComboBox"
                              DisplayMemberPath="Username"
                              SelectedValuePath="Id"
                              Margin="0,0,0,15" Padding="5"/>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,10">
                        <Button Content="Nowe urządzenie" Width="120" Margin="0,0,10,0" Click="AddDevice_Click" Background="#4CAF50" Foreground="White"/>
                        <Button Content="Zaktualizuj" Width="100" Margin="0,0,10,0" Click="UpdateDevice_Click" Background="#2196F3" Foreground="White"/>
                        <Button Content="Usuń" Width="80" Margin="0,0,10,0" Click="DeleteDevice_Click" Background="#F44336" Foreground="White"/>
                        <Button Content="Wyczyść" Width="80" Click="ClearForm_Click" Background="#9E9E9E" Foreground="White"/>
                    </StackPanel>

                    <TextBlock x:Name="StatusTextBlock" Foreground="Gray" Margin="0,10,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
