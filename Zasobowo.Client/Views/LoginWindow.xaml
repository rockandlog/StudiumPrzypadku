<Window x:Class="Zasobowo.Client.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Logowanie - Zasobowo" Height="450" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="#f3f3f3" ResizeMode="NoResize">
    <Border Background="White" CornerRadius="12" Margin="40" Padding="20" BorderBrush="#ccc" BorderThickness="1" >
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Zasobowo — Logowanie"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#333"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <Label Content="Email:" Grid.Row="1" />
            <TextBox x:Name="EmailTextBox" Grid.Row="2" Margin="0,5,0,15" Padding="5"/>

            <Label Content="Hasło:" Grid.Row="3" />
            <PasswordBox x:Name="PasswordBox" Grid.Row="4" Margin="0,5,0,15" Padding="5"/>

            <TextBlock x:Name="ErrorTextBlock"
                       Grid.Row="5"
                       Foreground="Red"
                       Visibility="Collapsed"
                       Margin="0,0,0,10"
                       TextWrapping="Wrap"
                       TextAlignment="Center" />

            <StackPanel Grid.Row="6" Orientation="Vertical" HorizontalAlignment="Center">
                <Button Content="Zaloguj"
                        Click="LoginButton_Click"
                        Width="100"
                        Height="35"
                        Margin="0,0,0,10"
                        Background="#0078D7"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderBrush="{x:Null}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Nie masz konta?" VerticalAlignment="Center"/>
                    <TextBlock VerticalAlignment="Center" Margin="5,0,0,0">
                        <Hyperlink Click="RegisterLink_Click">Zarejestruj się</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
