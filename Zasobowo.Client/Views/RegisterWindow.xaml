<Window x:Class="Zasobowo.Client.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rejestracja" Height="400" Width="400">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Email"/>
            <TextBox x:Name="EmailBox"/>

            <TextBlock Text="Hasło"/>
            <PasswordBox x:Name="PasswordBox"/>

            <TextBlock Text="Imię"/>
            <TextBox x:Name="FirstNameBox"/>

            <TextBlock Text="Nazwisko"/>
            <TextBox x:Name="LastNameBox"/>

            <TextBlock Text="Rola"/>
            <ComboBox x:Name="RoleBox">
                <ComboBoxItem Content="User"/>
                <ComboBoxItem Content="Admin"/>
            </ComboBox>

            <Button Content="Zarejestruj się" Click="RegisterButton_Click" Margin="0,10,0,0"/>
            <TextBlock x:Name="ErrorText" Visibility="Collapsed" Foreground="Red" Margin="0,10,0,0"/>

            <TextBlock>
                Masz już konto?
                <Hyperlink Click="LoginLink_Click">Zaloguj się</Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
